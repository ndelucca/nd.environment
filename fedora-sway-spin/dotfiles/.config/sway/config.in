# GENERADO desde config.in por setup/04-stow.sh — los nombres de output
# (@OUTPUT_INTERNAL@/@OUTPUT_EXTERNAL@) vienen de vars.sh (única fuente de verdad,
# compartida con kanshi). El `config` generado está git-ignored; editá el template
# .in, no el output.

set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term foot

# swayidle: las consume el 90-swayidle.conf del Spin vía include (definidas antes que él).
# No borrar aunque no se vean referencias locales — sin estas, el idle del Spin se rompe.
# Bloqueo a los 20 min; pantallas off 10 min después (30 min total).
set $lock_timeout 1200
set $screen_timeout 600

# Modos, combi, iconos, matching y tema viven en ~/.config/rofi/config.rasi
set $menu rofi -show drun
# Window switcher: salta a una ventana por nombre entre workspaces (modo `window` ya
# configurado en config.rasi). Complementa a $menu (drun), que solo lanza apps.
set $window rofi -show window

# Autostart. Los guardas `pkill -x` hacen idempotente a exec_always ante `reload`
# (si no, cada reload levantaría un daemon duplicado).
# wlsunset (night light) vive en el generado config.d/10-wlsunset.conf para que sus
# coordenadas vengan de vars.sh (LATITUDE/LONGITUDE) en vez de estar hardcodeadas.
exec_always pkill -x swaync;         exec swaync
exec_always pkill -x kanshi;         exec kanshi          # perfiles de output (~/.config/kanshi/config)
exec_always pkill -x swayosd-server; exec swayosd-server  # OSD de volumen/brillo/caps (ver binds en config.d)

# Historial de portapapeles (cliphist). `exec` (no exec_always) para que el reload no
# agregue watchers duplicados que guardarían dos veces cada copia.
exec wl-paste --type text  --watch cliphist store
exec wl-paste --type image --watch cliphist store

default_border pixel 2
default_floating_border pixel 2
titlebar_border_thickness 0
titlebar_padding 10 6
gaps inner 6
smart_gaps on
smart_borders on
workspace_auto_back_and_forth yes
focus_on_window_activation focus

# Hace que el cursor de Wayland coincida con el tema GTK (Adwaita 24). Las apps
# XWayland leen los mismos valores desde ~/.config/environment.d/cursor.conf.
seat seat0 xcursor_theme Adwaita 24

# swaymsg -t get_outputs
output * bg /usr/share/backgrounds/wallpaper.png fill

# swaymsg -t get_inputs
input type:touchpad {
    accel_profile flat
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
}

# La disposición de outputs (hotplug/dock) la maneja kanshi de forma declarativa
# (~/.config/kanshi/config + el servicio de usuario de kanshi). El estado de la tapa
# no es visible para kanshi, así que se maneja acá: desactiva el panel interno al cerrar.
bindswitch --reload --locked lid:on  output @OUTPUT_INTERNAL@ disable
bindswitch --reload --locked lid:off output @OUTPUT_INTERNAL@ enable

bindsym $mod+Return exec $term
bindsym $mod+q kill
bindsym $mod+d exec $menu
bindsym $mod+Tab exec $window
bindsym $mod+Shift+r reload
bindsym $mod+Shift+Escape exec loginctl lock-session
# Selector del historial de portapapeles (cliphist + rofi)
bindsym $mod+v exec cliphist list | rofi -dmenu -p "Clipboard" | cliphist decode | wl-copy

floating_modifier $mod normal

bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

bindsym $mod+f fullscreen toggle
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+c move position center
bindsym $mod+a focus parent

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Scratchpad: mandar la ventana enfocada / mostrar-ocultar (cicla si hay varias).
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Include en capas del Spin (/usr/share → /etc → ~/.config). Ante mismo nombre de
# archivo gana el directorio más específico: así overrideamos sin forkear el sistema.
include '$(/usr/libexec/sway/layered-include "/usr/share/sway/config.d/*.conf" "/etc/sway/config.d/*.conf" "${XDG_CONFIG_HOME:-$HOME/.config}/sway/config.d/*.conf")'

# Asignación de workspaces

workspace 7 output @OUTPUT_INTERNAL@ @OUTPUT_EXTERNAL@
workspace 1 output @OUTPUT_EXTERNAL@ @OUTPUT_INTERNAL@
workspace 2 output @OUTPUT_EXTERNAL@ @OUTPUT_INTERNAL@
workspace 3 output @OUTPUT_EXTERNAL@ @OUTPUT_INTERNAL@
workspace 4 output @OUTPUT_EXTERNAL@ @OUTPUT_INTERNAL@
workspace 5 output @OUTPUT_EXTERNAL@ @OUTPUT_INTERNAL@
workspace 6 output @OUTPUT_EXTERNAL@ @OUTPUT_INTERNAL@
workspace 8 output @OUTPUT_EXTERNAL@ @OUTPUT_INTERNAL@
workspace 9 output @OUTPUT_EXTERNAL@ @OUTPUT_INTERNAL@
workspace 10 output @OUTPUT_EXTERNAL@ @OUTPUT_INTERNAL@

assign [app_id="dev.zed.Zed"]  workspace 3
assign [app_id="neovide"]      workspace 3

# Las web-apps de Chromium reportan un app_id derivado de la URL con la forma
# `chrome-<host>__-Default` (igual para PWAs de Chromium y Google Chrome), no el
# valor de --class, así que se matchean por host. Anclado para no solaparse con la
# regla del navegador de abajo, así el matching es independiente del orden de reglas.
assign [app_id="^chrome-open\.spotify\.com"]    workspace 6
assign [app_id="^chrome-web\.whatsapp\.com"]    workspace 8
assign [app_id="^chrome-mail\.google\.com"]     workspace 10
# ChatGPT (otra PWA de 05-webapps.sh) NO se asigna a propósito: es una herramienta que se
# invoca contextualmente, así que se queda en el workspace activo en vez de tener uno fijo.

# Ventanas reales del navegador (no las web-apps). app_id exacto para que nunca
# colisionen con los ids chrome-<host> de las web-apps de arriba.
assign [app_id="^(chromium-browser|google-chrome|google-chrome-stable)$"] workspace 2
assign [app_id="^firefox$"] workspace 2
# Modos

mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Power menu en rofi (Lock/Logout/Suspend/Reboot/Shutdown), a juego con el sistema
bindsym $mod+BackSpace exec ~/.config/rofi/powermenu.sh

# Settings menu en rofi (Audio/Bluetooth/Notifications), a juego con el sistema
bindsym $mod+equal        exec ~/.config/rofi/settings.sh
bindsym $mod+exclamdown   exec ~/.config/rofi/settings.sh
bindsym $mod+questiondown exec ~/.config/rofi/settings.sh

